# Configuration pour le déploiement des smart contracts

# Réseau Sepolia (Testnet)
SEPOLIA_RPC_URL=https://sepolia.infura.io/v3/YOUR_INFURA_PROJECT_ID
MAINNET_RPC_URL=https://mainnet.infura.io/v3/YOUR_INFURA_PROJECT_ID

# Clé privée du compte déployeur (NE JAMAIS COMMITTER)
PRIVATE_KEY=0xYOUR_PRIVATE_KEY_WITHOUT_0x

# API Etherscan pour la vérification
ETHERSCAN_API_KEY=YOUR_ETHERSCAN_API_KEY

# Configuration optionnelle
REPORT_GAS=true